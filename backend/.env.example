PORT=5000
NODE_ENV=production

# CRITICAL: Generate a secure random secret for production
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then set the output below
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Neon PostgreSQL Connection String
# Get your connection string from: https://console.neon.tech
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=verify-full
DATABASE_URL=postgresql://neondb_owner:your_password@ep-xxxx.region.neon.tech/neondb?sslmode=verify-full&channel_binding=require

# Alternative: Individual connection parameters (if not using DATABASE_URL)
DB_HOST=ep-xxxx.us-east-1.neon.tech
DB_PORT=5432
DB_NAME=burpsite
DB_USER=neon_user
DB_PASSWORD=your_neon_password
DB_SSL=true

# Security & URLs
PROXY_PORT=8888
FRONTEND_URL=https://yourdomain.com  # Set to production frontend URL (HTTPS required in production)
# Optional: allow multiple frontend domains (comma-separated), e.g. production + preview
# FRONTEND_URLS=https://burpsite.vercel.app,https://burpsite-t3o3.vercel.app

# PRODUCTION CHECKLIST:
# [ ] JWT_SECRET is changed from default value
# [ ] DATABASE_URL uses sslmode=verify-full
# [ ] FRONTEND_URL is set to actual production domain (HTTPS only)
# [ ] NODE_ENV is set to 'production'
# [ ] All credentials are strong and stored securely
# [ ] Firewall rules restrict access to port 5000 (backend only for internal/API calls)
# [ ] Database backups are configured and tested
# [ ] SSL/TLS certificate is valid and not self-signed (unless test environment)
