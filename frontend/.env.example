# API endpoint configuration
# For local development, use localhost backend
# For production (Vercel), use REACT_APP_API_URL environment variable

# Local Development (http://localhost:5000)
REACT_APP_API_URL=http://localhost:5000/api

# Production on Vercel: Set REACT_APP_API_URL in Vercel dashboard
# Value: https://burpsite.onrender.com/api
